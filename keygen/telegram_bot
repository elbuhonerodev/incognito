#!/bin/bash
# ==============================================
# BOT TELEGRAM ADMIN - Instalación en VPS
# Bash installer: PHP + Nginx + Bot
# ==============================================

# Configuración del bot
BOT_TOKEN="8110328531:AAENaMQuzX25oAr_3R9G2a4ZUN37KDK2QbA"
ADMIN_ID=7250986566
BOT_DIR="/var/www/telegram_bot"
BOT_FILE="$BOT_DIR/telegram_bot.php"

# ================= FUNCIONES =================
msg() { echo -e "\e[1;32m[INFO]\e[0m $1"; }
err() { echo -e "\e[1;31m[ERROR]\e[0m $1"; }

# ================= INSTALACIÓN =================
msg "Actualizando sistema..."
apt update -y && apt upgrade -y

msg "Instalando dependencias necesarias..."
apt install -y php-fpm php-curl nginx curl unzip

# ================= CREAR BOT =================
msg "Creando directorio del bot..."
mkdir -p $BOT_DIR

cat > $BOT_FILE <<EOF
<?php
/*
 * BOT TELEGRAM ADMIN
 */

header("Content-Type: application/json");

\$BOT_TOKEN = "$BOT_TOKEN";
\$ADMIN_ID = $ADMIN_ID;

\$API = "https://api.telegram.org/bot\$BOT_TOKEN";

function tg_api(\$method, \$data = []) {
    global \$API;
    \$ch = curl_init("\$API/\$method");
    curl_setopt_array(\$ch, [
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_POST => true,
        CURLOPT_POSTFIELDS => \$data,
        CURLOPT_CONNECTTIMEOUT => 5,
        CURLOPT_TIMEOUT => 10
    ]);
    \$res = curl_exec(\$ch);
    curl_close(\$ch);
    return json_decode(\$res, true);
}

function sendMessage(\$chat_id, \$text) {
    return tg_api("sendMessage", [
        "chat_id" => \$chat_id,
        "text" => \$text,
        "parse_mode" => "HTML"
    ]);
}

\$update = json_decode(file_get_contents("php://input"), true);
if (!\$update || !isset(\$update['message'])) exit;

\$message = \$update['message'];
\$chat_id = \$message['chat']['id'];
\$user_id = \$message['from']['id'];
\$text = trim(\$message['text'] ?? "");

if (\$text === "/start") {
    if (\$user_id == \$ADMIN_ID) {
        sendMessage(\$chat_id, "👑 <b>BIENVENIDO ADMIN</b>\nBot PHP activo. Control total habilitado ✅");
    } else {
        sendMessage(\$chat_id, "⛔ <b>ACCESO DENEGADO</b>\nContacta al administrador.");
    }
}
EOF

chmod 644 $BOT_FILE

# ================= CONFIGURAR NGINX =================
msg "Configurando Nginx para servir el bot..."
NGINX_CONF="/etc/nginx/sites-available/telegram_bot"

cat > $NGINX_CONF <<EOF
server {
    listen 80;
    server_name _;

    root $BOT_DIR;
    index telegram_bot.php;

    location / {
        try_files \$uri /telegram_bot.php =404;
    }

    location ~ \.php\$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;')-fpm.sock;
    }
}
EOF

ln -sf $NGINX_CONF /etc/nginx/sites-enabled/
nginx -t && systemctl restart nginx

# ================= CONFIGURAR WEBHOOK =================
PUBLIC_IP=$(curl -s https://api.ipify.org)
BOT_URL="http://$PUBLIC_IP/telegram_bot.php"

msg "Activando webhook para Telegram..."
curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/setWebhook" -d "url=$BOT_URL" | jq

msg "Instalación completada!"
msg "Bot listo en: $BOT_URL"
msg "Envía /start desde Telegram para probar el bot"